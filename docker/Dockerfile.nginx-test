# ══════════════════════════════════════════════════════════════
# Test-only nginx image — serves web_portal SPA + proxies /api/
# to api-test. No SSL, no landing, no mini_app (not needed for portal tests).
# ══════════════════════════════════════════════════════════════

FROM node:22-alpine AS builder-webportal

WORKDIR /app/web_portal

COPY web_portal/package.json web_portal/package-lock.json* ./
RUN npm ci --silent

COPY web_portal/ ./
RUN npm run build

# ── Runtime image ──
FROM nginx:alpine

COPY --from=builder-webportal /app/web_portal/dist /usr/share/nginx/html/portal

# Overwrite default.conf with test-only config
RUN rm -f /etc/nginx/conf.d/default.conf
COPY nginx/conf.d/test.conf /etc/nginx/conf.d/test.conf

EXPOSE 80

HEALTHCHECK --interval=5s --timeout=3s --start-period=5s --retries=5 \
    CMD wget -qO- http://127.0.0.1/health || exit 1

CMD ["nginx", "-g", "daemon off;"]
