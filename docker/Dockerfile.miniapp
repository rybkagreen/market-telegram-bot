# Этап 1: сборка
FROM node:22-alpine AS builder

WORKDIR /app

# Копируем зависимости отдельно для кэша слоёв
COPY mini_app/package.json mini_app/package-lock.json* ./
RUN npm ci --silent

# Копируем исходники и собираем
COPY mini_app/ ./
RUN npm run build

# Этап 2: финальный образ — только собранные файлы
FROM alpine:3.20 AS dist

WORKDIR /dist

COPY --from=builder /app/dist ./
