# E2E test environment — loaded by docker-compose.test.yml
# Never use these secrets outside the isolated test stack.
DEBUG=true
ENABLE_E2E_AUTH=true

# Telegram bot — dummy values, widget/parser never runs in tests
BOT_TOKEN=e2e_dummy_token
API_ID=1
API_HASH=e2e_dummy_hash
TELETHON_SESSION_STRING=

# BL-107 Phase B.8 / BL-002 — route bot SDKs to the in-stack stub instead of api.telegram.org.
# Pair with SENTRY_ENVIRONMENT below: Settings validator rejects this combination when
# sentry_environment == "production" (R4 production guard layer 1).
TELEGRAM_API_BASE_URL=http://telegram-stub:8081
SENTRY_ENVIRONMENT=test

# Auth
JWT_SECRET=e2e_test_jwt_secret_not_for_production_use
FIELD_ENCRYPTION_KEY=RtCQfL3vSw82_mB7zG4x0YJpVhN1Ku5aeWqDXEr9kM8=
SEARCH_HASH_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
BOT_API_HMAC_SECRET=e2e_test_hmac_secret_not_for_production_use

# Postgres (isolated test DB)
POSTGRES_USER=e2e_test
POSTGRES_PASSWORD=e2e_test
POSTGRES_DB=e2e_test_db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://e2e_test:e2e_test@postgres-test:5432/e2e_test_db

# Redis (isolated)
REDIS_PORT=6379
REDIS_URL=redis://redis-test:6379/0
CELERY_BROKER_URL=redis://redis-test:6379/0
CELERY_RESULT_BACKEND=redis://redis-test:6379/1

# Ports
API_PORT=8001

# ORD stub (no real provider in tests)
ORD_PROVIDER=stub
ORD_BLOCK_WITHOUT_ERID=false

# Disable external services
MISTRAL_API_KEY=
SENTRY_DSN=
