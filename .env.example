# ══════════════════════════════════════════════════════════════
# TELEGRAM
# ══════════════════════════════════════════════════════════════
BOT_TOKEN=your_bot_token_here
ADMIN_IDS=123456789,987654321

# Telethon (парсер чатов)
API_ID=12345678
API_HASH=your_api_hash_here
TELETHON_SESSION_STRING=

# ══════════════════════════════════════════════════════════════
# БАЗА ДАННЫХ
# ══════════════════════════════════════════════════════════════
POSTGRES_USER=market_bot
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=market_bot_db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://market_bot:change_me_in_production@localhost:5432/market_bot_db

# ══════════════════════════════════════════════════════════════
# REDIS
# ══════════════════════════════════════════════════════════════
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ══════════════════════════════════════════════════════════════
# AI — Mistral (официальный API)
# Ключ: https://console.mistral.ai → API Keys → Create new key
# Бесплатный тир: 1 req/s, 500k токенов/месяц
# ══════════════════════════════════════════════════════════════
MISTRAL_API_KEY=your_mistral_api_key_here

# Модель (не менять без необходимости)
# mistral-medium-latest — баланс качества и скорости на бесплатном тире
AI_MODEL=mistral-medium-latest

# Параметры генерации
AI_TIMEOUT=60
AI_MAX_TOKENS=1500
AI_TEMPERATURE=0.7

# ══════════════════════════════════════════════════════════════
# JWT для Mini App аутентификации
# Генерировать: python -c "import secrets; print(secrets.token_hex(32))"
# ══════════════════════════════════════════════════════════════
JWT_SECRET=your_jwt_secret_here_generate_with_python_secrets
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# ══════════════════════════════════════════════════════════════
# ПЛАТЕЖИ
# ══════════════════════════════════════════════════════════════

# CryptoBot (получить на @CryptoBot → My Apps → Create App)
CRYPTOBOT_TOKEN=your_cryptobot_token_here

# Telegram Stars
STARS_ENABLED=true

# ЮKassa (банковские карты, СБП, ЮMoney)
YOOKASSA_SHOP_ID=your_shop_id_here
YOOKASSA_SECRET_KEY=your_secret_key_here
YOOKASSA_RETURN_URL=https://t.me/YOUR_BOT_USERNAME

# Курсы конвертации (кредитов за 1 единицу валюты)
CREDITS_PER_USDT=90
CREDITS_PER_TON=400
CREDITS_PER_BTC=9000000
CREDITS_PER_ETH=300000
CREDITS_PER_LTC=7000
CREDITS_PER_STAR=2

# Бонусы за объём
BONUS_CREDITS_STANDARD=100
BONUS_CREDITS_BUSINESS=500

# ══════════════════════════════════════════════════════════════
# ПРИЛОЖЕНИЕ
# ══════════════════════════════════════════════════════════════
ENVIRONMENT=development
DEBUG=true

# Порты
API_PORT=8001
FLOWER_PORT=5555
NGINX_PORT=8080

# Тарификация
PLAN_RENEWAL_CHECK_HOUR=3

# URLs (для production)
WEBHOOK_URL=https://yourdomain.com/webhook
MINI_APP_URL=https://yourdomain.com/app

# Sentry (для production)
SENTRY_DSN=your_sentry_dsn_here
