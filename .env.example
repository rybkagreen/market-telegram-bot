# Telegram Bot
BOT_TOKEN=your_bot_token_here

# Telegram API (–і–ї—П –њ–∞—А—Б–µ—А–∞)
API_ID=your_api_id_here
API_HASH=your_api_hash_here

# PostgreSQL
POSTGRES_USER=market_bot
POSTGRES_PASSWORD=market_bot_pass
POSTGRES_DB=market_bot_db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://market_bot:market_bot_pass@localhost:5432/market_bot_db

# Redis
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Ports
API_PORT=8001
FLOWER_PORT=5555
NGINX_PORT=80

# Environment
ENVIRONMENT=development
DEBUG=true

# AI Services
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
GROQ_API_KEY=gsk_your_groq_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here

# AI Provider (groq | openai | openrouter | mock)
AI_PROVIDER=groq
AI_MODEL=llama-3.3-70b-versatile

# OpenRouter –Љ–Њ–і–µ–ї—М (–і–ї—П PRO –Є BUSINESS —В–∞—А–Є—Д–Њ–≤ вАФ Claude Sonnet)
OPENROUTER_MODEL=anthropic/claude-sonnet-4-20250514

# AI –њ–∞—А–∞–Љ–µ—В—А—Л –≥–µ–љ–µ—А–∞—Ж–Є–Є
AI_MAX_TOKENS=1024
AI_TEMPERATURE=0.7

# AI Cost
AI_COST_PER_GENERATION=10

# Payments
YOOKASSA_SHOP_ID=your_yookassa_shop_id_here
YOOKASSA_SECRET_KEY=your_yookassa_secret_key_here

# Admin IDs (comma-separated Telegram IDs)
ADMIN_IDS=123456789,987654321

# Webhook & Mini App (–і–ї—П production)
WEBHOOK_URL=https://yourdomain.com/webhook
MINI_APP_URL=https://yourdomain.com/app

# Sentry (–і–ї—П production)
SENTRY_DSN=your_sentry_dsn_here
""  
