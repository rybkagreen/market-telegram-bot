{
  "python": {
    "command": "/opt/market-telegram-bot/.venv/bin/pylsp",
    "args": ["--check-parent-process", "--verbose"],
    "env": {
      "PYTHONPATH": "/opt/market-telegram-bot/src"
    },
    "settings": {
      "pylsp": {
        "plugins": {
          "pycodestyle": { "enabled": false },
          "pyflakes": { "enabled": true },
          "mccabe": { "enabled": false },
          "pylint": { "enabled": false },
          "rope_rename": { "enabled": true },
          "rope_autoimport": { 
            "enabled": true,
            "execute": false
          },
          "jedi_completion": { 
            "enabled": true, 
            "include_params": true,
            "include_class_objects": true,
            "include_function_objects": true
          },
          "jedi_signature_help": { "enabled": true },
          "jedi_hover": { "enabled": true },
          "jedi_references": { "enabled": true },
          "jedi_definition": { 
            "enabled": true, 
            "follow_imports": true,
            "follow_builtin_imports": true
          },
          "flake8_lint": { "enabled": false },
          "yapf": { "enabled": false },
          "autopep8": { "enabled": false }
        }
      }
    },
    "extensionToLanguage": {
      ".py": "python"
    },
    "startupTimeout": 30000
  },
  "typescript": {
    "command": "typescript-language-server",
    "args": ["--stdio"],
    "settings": {
      "typescript": {
        "tsdk": "/opt/market-telegram-bot/web_portal/node_modules/typescript/lib",
        "preferences": {
          "includeCompletionsForModuleExports": true,
          "includeCompletionsWithInsertText": true,
          "includeAutomaticOptionalChainCompletions": true,
          "includeCompletionsWithClassMemberSnippets": true,
          "includeCompletionsWithObjectLiteralMethodSnippets": true,
          "providePrefixAndSuffixTextForRename": true,
          "allowRenameOfImportPath": true,
          "displayPartsForDocumentation": true
        }
      },
      "javascript": {
        "preferences": {
          "includeCompletionsForModuleExports": true
        }
      }
    },
    "extensionToLanguage": {
      ".ts": "typescript",
      ".tsx": "typescript",
      ".js": "javascript",
      ".jsx": "javascript"
    },
    "startupTimeout": 30000
  }
}
